# Project 1: Password Strength Checker
def check_password_strength(password):
    # Setting up flags (Boolean variables)
    has_upper = False
    has_lower = False
    has_digit = False
    has_special = False
    
    # Special characters to look for in network security audits
    special_chars = "!@#$%^&*(),.?\":{}|<>"
    
    # Loop through each character in the password
    for char in password:
        if char.isupper():
            has_upper = True
        elif char.islower():
            has_lower = True
        elif char.isdigit():
            has_digit = True
        elif char in special_chars:
            has_special = True

    # Calculate overall security score based on criteria met
    score = sum([has_upper, has_lower, has_digit, has_special])
    
    print(f"Analyzing Password Complexity: {password}")
    
    if len(password) < 8:
        return "❌ Weak: Password must be at least 8 characters long."
    elif score == 4:
        return "✅ Strong: Excellent cryptographic resilience!"
    elif score >= 2:
        return "⚠️ Medium: Vulnerable to basic dictionary attacks. Add more symbols."
    else:
        return "❌ Weak: Fails baseline network security policy requirements."

# Demonstration execution to verify logic
print(check_password_strength("school123"))
print(check_password_strength("SecureP@ss2026!"))
